# === gather-clone Backend (Express + MongoDB) ===

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gather-clone

# Server
PORT=5001
NODE_ENV=development

# JWT
JWT_SECRET=dev-secret-key-change-in-production

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=

# Email OTP (Gmail App Password)
EMAIL_USER=
EMAIL_PASS=

# ==========================================
# PRODUCTION (Render) - set trên dashboard:
# ==========================================
# MONGODB_URI=mongodb+srv://...@cluster.mongodb.net/TheGatheringDB?retryWrites=true&w=majority
# PORT=5001
# NODE_ENV=production
# JWT_SECRET=<strong-random-secret>
# CLIENT_URL=https://thegathering1.netlify.app
# GOOGLE_CLIENT_ID=<your-google-client-id>
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
