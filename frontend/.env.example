# === gather-clone Frontend (Next.js) ===

# Backend URL (Express API + Socket.IO)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# App URL (dùng cho invite link, redirect)
NEXT_PUBLIC_BASE_URL=http://localhost:5173

# Google OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ==========================================
# PRODUCTION (Netlify) - set trên dashboard:
